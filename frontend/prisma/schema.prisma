generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())

  orders            Order[]
  communicationLogs CommunicationLog[]
}

model Order {
  id         String   @id @default(uuid())
  customerId String
  amount     Float
  status     String   @default("completed") // completed, refunded
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id            String   @id @default(uuid())
  name          String
  audienceQuery String   // Natural language intent
  messageBody   String
  channel       String   // whatsapp, email, sms
  status        String   @default("draft") // draft, executing, completed
  createdAt     DateTime @default(now())

  communications CommunicationLog[]
}

model CommunicationLog {
  id         String   @id @default(uuid())
  campaignId String
  customerId String
  channel    String
  status     String   @default("PENDING") // PENDING, DELIVERED, FAILED, OPENED, CLICKED
  message    String?  // The dynamically personalized message
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
